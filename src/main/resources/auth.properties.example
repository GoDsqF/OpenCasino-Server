# Sample auth.properties — copy to auth.properties and fill in for your environment.
# The real auth.properties is gitignored; mount it at runtime via /config or supply env vars.

# ---------------- JWT (Phase 4) ----------------
# Issuer claim baked into every access token. Resource server rejects tokens
# whose `iss` claim does not match this value.
app.jwt.issuer=${APP_JWT_ISSUER:opencasino}

# Access-token TTL (ISO-8601 duration). Refresh-token rotation lands in phase 7.
app.jwt.accessTtl=${APP_JWT_ACCESS_TTL:PT15M}

# Key id stamped into the JWT header. Required for key rotation (phase 7+).
app.jwt.keyId=${APP_JWT_KEY_ID:default}

# RS256 keypair (PEM, PKCS#8 for the private key, X.509 SubjectPublicKeyInfo for the public).
# Generate locally:
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out jwt-private.pem
#   openssl rsa -in jwt-private.pem -pubout -out jwt-public.pem
# Then paste the file contents below. In production prefer env vars
# APP_JWT_PRIVATE_KEY_PEM / APP_JWT_PUBLIC_KEY_PEM (raw multiline content).
app.jwt.privateKeyPem=${APP_JWT_PRIVATE_KEY_PEM:}
app.jwt.publicKeyPem=${APP_JWT_PUBLIC_KEY_PEM:}

# ---------------- Display-name policy (Phase 5) ----------------
# Comma-separated case-insensitive substrings that may not appear in a user's display name
# (validated at /auth/register). Length is fixed at 3..32 chars matching [A-Za-z0-9_-]+.
app.auth.displayNameBlocklist=${APP_AUTH_DISPLAY_NAME_BLOCKLIST:admin,root,system,support,moderator}

# ---------------- OAuth2 client (Phase 6) ----------------
# Google as identity provider. Leave the env vars blank to skip OAuth wiring
# entirely — the rest of the app starts unaffected, /oauth2/authorization/google
# returns 404 (no registration). Set both to enable the flow.
spring.security.oauth2.client.registration.google.client-id=${GOOGLE_OAUTH_CLIENT_ID:}
spring.security.oauth2.client.registration.google.client-secret=${GOOGLE_OAUTH_CLIENT_SECRET:}
spring.security.oauth2.client.registration.google.scope=openid,email,profile

# Where the server 302-redirects after a successful OAuth login, carrying
# ?token=<jwt>&expiresAt=<iso>. Single URI per environment (dev: localhost,
# prod: real domain). Override via env in prod.
app.auth.oauth2.success-redirect=${APP_AUTH_OAUTH2_SUCCESS:http://localhost:3000/oauth2/redirect}

# Where the server 302-redirects on OAuth failure with ?error=<code>.
# When unset, falls back to success-redirect.
app.auth.oauth2.failure-redirect=${APP_AUTH_OAUTH2_FAILURE:}